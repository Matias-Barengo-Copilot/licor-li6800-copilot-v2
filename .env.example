# Program IQ — Backend environment variables
# Copy to .env and fill in real values

# Neon PostgreSQL read-only connection string (SELECT only — never use write credentials here)
DATABASE_URL_READONLY=postgresql://readonly_user:pass@host.neon.tech/dbname?sslmode=require

# JWT secret — MUST match the value in Smart-Attendance/backend/.env exactly
JWT_SECRET=change-me-to-a-long-random-secret

# Required for chat feature (GPT-4o)
OPENAI_API_KEY=

# Optional: enables Claude Sonnet NL queries; degrades gracefully if absent
ANTHROPIC_API_KEY=
